{
  "site": "robertdelanghe.dev",
  "_note": "Consumes the shared synoptic engine. Markdown = composed posts. Grounding lives in data/audit/grounding.json; the token-grounding layer waits on a flat claim-token source (follow-up).",
  "layers": {
    "markdown": {
      "proseCorpus": "prose-corpus.json",
      "docCorpus": "doc-corpus.json",
      "source": {
        "docsDir": "posts",
        "pages": []
      }
    }
  },
  "graph": {
    "id": "https://robertdelanghe.dev/#person",
    "plugins": [
      "resume",
      "palette"
    ],
    "bridge": [
      {
        "predicate": "affiliation",
        "id": "https://bounded.tools/#org"
      }
    ]
  },
  "build": {
    "theme": {
      "text": "--color-ink",
      "surface": "--color-paper",
      "accent": "--color-forest",
      "border": "--color-line",
      "font": "--font-display",
      "mono": "--font-mono"
    },
    "pages": [
      {
        "id": "who",
        "route": "who",
        "title": "Robert Delanghe",
        "sections": [
          {
            "title": "Profile",
            "query": {
              "type": "Person"
            },
            "render": "hero"
          },
          {
            "title": "Work",
            "query": {
              "type": "Organization"
            }
          }
        ]
      }
    ]
  }
}
