{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robertdelanghe.dev/contract/profile.schema.json",
  "title": "profile / copy contract",
  "description": "Content tokens (slugs for copy) for the site's identity. Curated from a saved source (e.g. a LinkedIn webarchive), version-controlled, never live-fetched. build.mjs renders from these slugs.",
  "type": "object",
  "required": ["name", "role", "headline", "summary", "links"],
  "additionalProperties": true,
  "properties": {
    "name": { "type": "string" },
    "role": { "type": "string" },
    "place": { "type": "string" },
    "headline": { "type": "string", "description": "hero h1 — one line" },
    "summary": { "type": "string", "description": "hero lead paragraph" },
    "experience": {
      "type": "array",
      "description": "Roles, newest first. Curated from a saved source, not live.",
      "items": {
        "type": "object",
        "required": ["org", "when", "what"],
        "additionalProperties": false,
        "properties": {
          "org": { "type": "string" },
          "role": { "type": "string" },
          "when": { "type": "string" },
          "what": { "type": "string" }
        }
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["org", "when", "what"],
        "additionalProperties": false,
        "properties": {
          "org": { "type": "string" },
          "when": { "type": "string" },
          "what": { "type": "string" }
        }
      }
    },
    "links": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["label", "href"],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string" },
          "href": { "type": "string" }
        }
      }
    }
  }
}
