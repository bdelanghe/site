{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robertdelanghe.dev/contract/site.schema.json",
  "title": "robertdelanghe.dev site data contract",
  "description": "The single source of truth the site renders from. fetch.mjs produces it (network); build.mjs consumes it (pure). Drift from this shape fails the build.",
  "type": "object",
  "required": ["generatedAt", "owner", "stats", "highlights"],
  "additionalProperties": false,
  "properties": {
    "generatedAt": { "type": "string", "format": "date-time" },
    "owner": {
      "type": "object",
      "required": ["login", "name"],
      "additionalProperties": true,
      "properties": {
        "login": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "stats": {
      "type": "object",
      "description": "Aggregate meta-analysis over the WHOLE corpus (public + private). No private names ever appear here.",
      "required": ["repos", "public", "private", "sources", "forks", "languages", "tagged", "topics"],
      "additionalProperties": false,
      "properties": {
        "repos": { "type": "integer" },
        "public": { "type": "integer" },
        "private": { "type": "integer" },
        "sources": { "type": "integer" },
        "forks": { "type": "integer" },
        "tagged": { "type": "integer", "description": "public source repos with >= 1 topic" },
        "languages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "count"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "count": { "type": "integer" }
            }
          }
        },
        "topics": {
          "type": "array",
          "description": "topic vocabulary in use across public repos, with counts",
          "items": {
            "type": "object",
            "required": ["name", "count"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "count": { "type": "integer" }
            }
          }
        }
      }
    },
    "highlights": {
      "type": "array",
      "description": "Curated, PUBLIC, non-fork projects to show. Clean subset, not everything.",
      "items": {
        "type": "object",
        "required": ["name", "fullName", "url", "description"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "fullName": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "description": { "type": "string" },
          "language": { "type": ["string", "null"] },
          "stars": { "type": "integer" },
          "pinned": { "type": "boolean" },
          "topics": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
